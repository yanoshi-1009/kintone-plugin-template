{
  "name": "kintone-plugin-master",
  "version": "1.0.0",
  "description": "This is kintone plugin template.",
  "keywords": [
    "kintone"
  ],
  "author": "y.idakko@gmail.com",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yanoshi-1009/kintone-plugin-template"
  },
  "type": "module",
  "main": "index.js",
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": ">=24.0.0",
      "onFail": "error"
    },
    "packageManager": {
      "name": "pnpm",
      "version": ">=10.0.0",
      "onFail": "error"
    }
  },
  "scripts": {
    "init": "node ./scripts/init.ts",
    "upload": "node ./scripts/upload.ts",
    "build:prod": "node ./scripts/build-prod.ts",
    "build:dev": "node ./scripts/build-dev.ts"
  },
  "dependencies": {
    "@kintone/rest-api-client": "6.1.5",
    "dayjs": "1.11.20",
    "i18next": "26.0.4",
    "kintone-ui-component": "1.24.0"
  },
  "devDependencies": {
    "@cybozu/eslint-config": "25.0.1",
    "@kintone/cli": "1.19.2",
    "@kintone/dts-gen": "9.0.5",
    "@types/node": "25.6.0",
    "esbuild": "0.28.0",
    "eslint": "9.39.4",
    "prettier": "3.8.2",
    "typescript": "6.0.2"
  }
}
