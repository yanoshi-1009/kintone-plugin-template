{
  "extends": [
    "config:recommended",
    ":automergeMinor",
    ":maintainLockFilesWeekly",
    ":skipStatusChecks"
  ],
  "timezone": "Asia/Tokyo",
  "schedule": "before 6am",
  "minimumReleaseAge": "1 days",
  "labels": ["renovate"],
  "assignees": ["yanoshi-1009"],
  "rangeStrategy": "pin",
  "lockFileMaintenance": {
    "automerge": true
  },
  "packageRules": [
    {
      "matchPackageNames": ["@cybozu/eslint-config", "typescript"],
      "automerge": true
    },
    {
      "matchPackageNames": ["node", "pnpm"],
      "enabled": false
    }
  ]
}
